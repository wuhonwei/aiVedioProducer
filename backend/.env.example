# Copy to .env and adjust as needed. All variables use the AIVP_ prefix.

AIVP_OLLAMA_BASE_URL=http://127.0.0.1:11434
AIVP_OLLAMA_MODEL=qwen2.5:14b
AIVP_DATA_ROOT=data
AIVP_DB_URL=sqlite:///./data/aivp.db

# DeepSeek for shot scripts (do not commit real keys)
AIVP_DEEPSEEK_API_KEY=
AIVP_DEEPSEEK_BASE_URL=https://api.deepseek.com
AIVP_DEEPSEEK_MODEL=deepseek-v4-flash

# Visual / LoRA — use project-only Comfy at tools/ComfyUI (port 8190), not a shared 8188
AIVP_IMAGE_BACKEND=comfy
AIVP_COMFY_BASE_URL=http://127.0.0.1:8190
# Filename under tools/ComfyUI/models/checkpoints/
AIVP_COMFY_CHECKPOINT=Guofeng4.2XL.safetensors
AIVP_LORA_TRAIN_CMD=

# Million-char / long novel (optional)
# AIVP_EXTRACT_WORKERS=4
# AIVP_EXTRACT_PROGRESS_EVERY=10
# AIVP_CHUNK_SIZE=6000
# AIVP_VOLUME_MAX_CHARS=80000
# AIVP_VOLUME_MAX_CHAPTERS=40
# AIVP_ENRICH_EVENT_WINDOW=40
# AIVP_ENRICH_REQUIRE_DISTINCT_CHARACTERS=true
# AIVP_TIMELINE_PAGE_SIZE=50
# AIVP_API_PAGE_SIZE=50
